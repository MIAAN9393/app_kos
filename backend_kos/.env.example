PORT=3000
NODE_ENV=development

# Security
# Pisahkan dengan koma. Wajib isi origin frontend di production, contoh:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=
JSON_BODY_LIMIT=1mb
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
PUBLIC_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_RATE_LIMIT_MAX=120
WEBHOOK_RATE_LIMIT_WINDOW_MS=900000
WEBHOOK_RATE_LIMIT_MAX=600

# Database
DB_HOST=localhost
DB_PORT=
DB_USER=root
DB_PASSWORD=
DB_NAME=app_kos
DB_SYNC=true

# JWT
JWT_SECRET=isi_jwt_secret
JWT_REFRESH_SECRET=isi_jwt_refresh_secret_wajib_berbeda_dari_jwt_secret

# Google OAuth
GOOGLE_CLIENT_ID=isi_web_client_id_google

# Cloudinary
CLOUDINARY_CLOUD_NAME=isi_cloud_name
CLOUDINARY_API_KEY=isi_api_key
CLOUDINARY_API_SECRET=isi_api_secret

# Midtrans Snap
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
APP_URL=
FRONTEND_URL=
